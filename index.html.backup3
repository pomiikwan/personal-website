<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>关威雄个人网站 - 多端响应式版本（专业图标版）</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        background: 'hsl(var(--background))',
                        foreground: 'hsl(var(--foreground))',
                        card: 'hsl(var(--card))',
                        border: 'hsl(var(--border))',
                        'tech-cyan': 'hsl(var(--tech-cyan))',
                        'finance-gold': 'hsl(var(--finance-gold))',
                        'tactical-green': 'hsl(var(--tactical-green))',
                    },
                }
            }
        }
    </script>
    <style>
        /* 军事科技金融风格 - 深色主题 */
        :root {
            --background: 150 20% 6%;
            --foreground: 140 30% 92%;
            --card: 150 18% 10%;
            --border: 150 15% 18%;
            --tech-cyan: 175 85% 45%;
            --finance-gold: 45 95% 55%;
            --military-olive: 80 40% 30%;
            --tactical-green: 150 60% 40%;
        }

        body {
            background: hsl(var(--background));
            color: hsl(var(--foreground));
        }

        /* 扫描线动画 */
        .scanline {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            background: repeating-linear-gradient(
                0deg,
                rgba(0, 0, 0, 0.15),
                rgba(0, 0, 0, 0.15) 1px,
                transparent 1px,
                transparent 2px
            );
            animation: scanline 8s linear infinite;
            z-index: 0;
        }

        @keyframes scanline {
            0% { transform: translateY(0); }
            100% { transform: translateY(100px); }
        }

        /* 科技发光效果 */
        .tech-glow {
            box-shadow: 0 0 20px hsl(var(--tech-cyan) / 0.3);
        }

        /* 角标装饰 */
        .corner-deco {
            position: relative;
        }

        .corner-deco::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 16px;
            height: 16px;
            border-top: 2px solid hsl(var(--tech-cyan));
            border-left: 2px solid hsl(var(--tech-cyan));
        }

        .corner-deco::after {
            content: '';
            position: absolute;
            bottom: 0;
            right: 0;
            width: 16px;
            height: 16px;
            border-bottom: 2px solid hsl(var(--tech-cyan));
            border-right: 2px solid hsl(var(--tech-cyan));
        }

        @media (min-width: 768px) {
            .corner-deco::before,
            .corner-deco::after {
                width: 20px;
                height: 20px;
            }
        }

        /* 导航样式 */
        .desktop-nav {
            display: none;
        }

        .bottom-nav {
            display: flex;
        }

        @media (min-width: 1024px) {
            .desktop-nav {
                display: block;
            }
            .bottom-nav {
                display: none;
            }
        }

        /* 卡片悬浮效果 */
        .card-hover {
            transition: all 0.3s ease;
        }
        .card-hover:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
        }

        /* 隐藏滚动条 */
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        /* 渐变文字 */
        .gradient-text {
            background: linear-gradient(to right, hsl(var(--tech-cyan)), hsl(var(--finance-gold)));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* 按钮样式 */
        .btn-primary {
            background: linear-gradient(to right, hsl(var(--tech-cyan)), hsl(var(--tactical-green)));
            color: hsl(var(--background));
        }

        .btn-primary:hover {
            opacity: 0.9;
        }

        .btn-secondary {
            background: hsl(var(--card));
            border: 1px solid hsl(var(--tech-cyan) / 0.5);
            color: hsl(var(--tech-cyan));
        }

        .btn-secondary:hover {
            background: hsl(var(--tech-cyan) / 0.1);
        }

        /* 服务卡片 */
        .service-card {
            background: hsl(var(--card));
            border: 1px solid hsl(var(--border));
            border-radius: 0.5rem;
            transition: all 0.3s ease;
        }

        .service-card:hover {
            border-color: hsl(var(--tech-cyan));
            box-shadow: 0 0 20px hsl(var(--tech-cyan) / 0.2);
        }

        /* 响应式容器 */
        .container-custom {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 1rem;
        }

        @media (min-width: 640px) {
            .container-custom {
                padding: 0 2rem;
            }
        }

        @media (min-width: 1024px) {
            .container-custom {
                padding: 0 4rem;
            }
        }

        /* 图标容器 */
        .icon-container {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 100%;
        }

        /* 移动端优化 */
        @media (max-width: 767px) {
            .mobile-full-width {
                padding-left: 0;
                padding-right: 0;
            }

            .mobile-card {
                border-radius: 0;
                border-left: none;
                border-right: none;
            }
        }

        /* 图标动画 */
        .icon-pulse {
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }

        @keyframes pulse {
            0%, 100% {
                opacity: 1;
            }
            50% {
                opacity: .5;
            }
        }
    </style>
</head>
<body class="antialiased">
    <div class="scanline"></div>

    <!-- 桌面端导航 -->
    <nav class="desktop-nav fixed top-0 left-0 right-0 z-50 bg-background/95 backdrop-blur border-b border-border">
        <div class="container-custom">
            <div class="flex items-center justify-between h-16">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-tech-cyan to-tactical-green flex items-center justify-center">
                        <i data-lucide="zap" class="w-5 h-5 text-background"></i>
                    </div>
                    <span class="font-bold text-xl">关威雄</span>
                </div>
                <div class="hidden lg:flex items-center gap-8">
                    <a href="index.html" class="text-tech-cyan transition flex items-center gap-2">
                        <i data-lucide="home" class="w-4 h-4"></i>
                        首页
                    </a>
                    <a href="about.html" class="hover:text-tech-cyan transition flex items-center gap-2">
                        <i data-lucide="user" class="w-4 h-4"></i>
                        关于我
                    </a>
                    <a href="services.html" class="hover:text-tech-cyan transition flex items-center gap-2">
                        <i data-lucide="grid-3x3" class="w-4 h-4"></i>
                        服务市场
                    </a>
                    <a href="cases.html" class="hover:text-tech-cyan transition flex items-center gap-2">
                        <i data-lucide="folder-open" class="w-4 h-4"></i>
                        案例研究
                    </a>
                    <a href="blog.html" class="hover:text-tech-cyan transition flex items-center gap-2">
                        <i data-lucide="file-text" class="w-4 h-4"></i>
                        博客
                    </a>
                    <a href="api-playground.html" class="hover:text-tech-cyan transition flex items-center gap-2">
                        <i data-lucide="code" class="w-4 h-4"></i>
                        API
                    </a>
                </div>
                <div class="hidden lg:flex items-center gap-4">
                    <button class="px-4 py-2 text-sm font-medium text-tech-cyan hover:text-tech-cyan/80 transition flex items-center gap-2">
                        <i data-lucide="log-in" class="w-4 h-4"></i>
                        登录
                    </button>
                    <button class="px-4 py-2 bg-tech-cyan text-background text-sm font-medium rounded-lg hover:opacity-90 transition flex items-center gap-2 tech-glow">
                        <i data-lucide="user-plus" class="w-4 h-4"></i>
                        注册
                    </button>
                </div>
            </div>
        </div>
    </nav>
    <!-- 移动端顶部导航 -->
    <nav class="lg:hidden fixed top-0 left-0 right-0 z-50 bg-background/95 backdrop-blur border-b border-border">
        <div class="px-4 py-3">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-tech-cyan to-tactical-green flex items-center justify-center">
                        <i data-lucide="zap" class="w-4 h-4 text-background"></i>
                    </div>
                    <span class="font-bold text-lg">关威雄</span>
                </div>
                <div class="flex items-center gap-3">
                    <button class="p-2 hover:bg-card/50 rounded-lg transition">
                        <i data-lucide="search" class="w-5 h-5"></i>
                    </button>
                    <button class="p-2 hover:bg-card/50 rounded-lg transition">
                        <i data-lucide="user" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- 主内容区域 -->
    <main class="relative z-10">
        <!-- Hero Section -->
        <section id="home" class="min-h-screen flex items-center pt-16 lg:pt-16 pb-20">
            <div class="container-custom py-12 lg:py-20">
                <div class="grid lg:grid-cols-2 gap-12 items-center">
                    <!-- 左侧：文字内容 -->
                    <div class="text-center lg:text-left">
                        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-4">
                            <span class="gradient-text">关威雄</span>
                        </h1>
                        <h2 class="text-xl sm:text-2xl lg:text-3xl text-foreground/80 mb-6">
                            资产架构师
                        </h2>
                        <p class="text-base sm:text-lg lg:text-xl text-foreground/70 mb-8 leading-relaxed">
                            极端市场环境下的资产保全与增值专家<br class="hidden sm:block"/>
                            16年专注一件事：<span class="text-tech-cyan">在极端市场环境下实现资产的保全与增值</span>
                        </p>

                        <!-- 核心数据 - 响应式布局 -->
                        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-4 mb-8">
                            <div class="bg-card border border-border rounded-lg p-3 lg:p-4 corner-deco">
                                <div class="text-2xl lg:text-3xl font-bold text-tech-cyan flex items-center justify-center gap-2">
                                    <i data-lucide="trending-up" class="w-5 h-5 lg:w-6 lg:h-6"></i>
                                    <span>16+</span>
                                </div>
                                <div class="text-xs lg:text-sm text-foreground/60 mt-1">年实战经验</div>
                            </div>
                            <div class="bg-card border border-border rounded-lg p-3 lg:p-4 corner-deco">
                                <div class="text-2xl lg:text-3xl font-bold text-finance-gold flex items-center justify-center gap-2">
                                    <i data-lucide="line-chart" class="w-5 h-5 lg:w-6 lg:h-6"></i>
                                    <span>489%</span>
                                </div>
                                <div class="text-xs lg:text-sm text-foreground/60 mt-1">最佳基金收益</div>
                            </div>
                            <div class="bg-card border border-border rounded-lg p-3 lg:p-4 corner-deco">
                                <div class="text-2xl lg:text-3xl font-bold text-tactical-green flex items-center justify-center gap-2">
                                    <i data-lucide="check-circle-2" class="w-5 h-5 lg:w-6 lg:h-6"></i>
                                    <span>100%</span>
                                </div>
                                <div class="text-xs lg:text-sm text-foreground/60 mt-1">账户正收益</div>
                            </div>
                            <div class="bg-card border border-border rounded-lg p-3 lg:p-4 corner-deco col-span-2 lg:col-span-1">
                                <div class="text-2xl lg:text-3xl font-bold text-tech-cyan flex items-center justify-center gap-2">
                                    <i data-lucide="building-2" class="w-5 h-5 lg:w-6 lg:h-6"></i>
                                    <span>3</span>
                                </div>
                                <div class="text-xs lg:text-sm text-foreground/60 mt-1">私募基金主体</div>
                            </div>
                        </div>

                        <!-- CTA按钮 -->
                        <div class="flex flex-col sm:flex-row gap-3 lg:gap-4">
                            <button class="px-8 py-3 btn-primary font-semibold rounded-lg transition tech-glow flex items-center justify-center gap-2">
                                <i data-lucide="target" class="w-5 h-5"></i>
                                了解我的能力
                            </button>
                            <button class="px-8 py-3 btn-secondary font-semibold rounded-lg transition flex items-center justify-center gap-2">
                                <i data-lucide="layout-grid" class="w-5 h-5"></i>
                                查看服务接口
                            </button>
                        </div>
                    </div>

                    <!-- 右侧：SXA模型 -->
                    <div class="bg-card border border-border rounded-lg p-6 lg:p-8 corner-deco">
                        <div class="text-center mb-4">
                            <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-xl bg-tech-cyan/20 border-2 border-tech-cyan flex items-center justify-center mx-auto mb-3">
                                <i data-lucide="zap" class="w-8 h-8 lg:w-10 lg:h-10 text-tech-cyan icon-pulse"></i>
                            </div>
                            <h3 class="text-xl lg:text-2xl font-bold">SXA反身性交易模型</h3>
                            <p class="text-xs sm:text-sm text-foreground/60 mt-2">
                                基于索罗斯理论的量化+主观混合策略
                            </p>
                        </div>

                        <!-- 流程图 -->
                        <div class="flex items-center justify-between mb-4 lg:mb-6">
                            <div class="flex flex-col items-center gap-2 lg:gap-3">
                                <div class="w-14 h-14 lg:w-20 lg:h-20 rounded-full bg-tech-cyan/20 border-2 border-tech-cyan flex items-center justify-center">
                                    <i data-lucide="search" class="w-6 h-6 lg:w-8 lg:h-8 text-tech-cyan"></i>
                                </div>
                                <span class="text-xs font-semibold">研判</span>
                            </div>
                            <i data-lucide="chevron-right" class="w-6 h-6 lg:w-8 lg:h-8 text-tech-cyan/50 flex-shrink-0"></i>
                            <div class="flex flex-col items-center gap-2 lg:gap-3">
                                <div class="w-14 h-14 lg:w-20 lg:h-20 rounded-full bg-finance-gold/20 border-2 border-finance-gold flex items-center justify-center">
                                    <i data-lucide="lightbulb" class="w-6 h-6 lg:w-8 lg:h-8 text-finance-gold"></i>
                                </div>
                                <span class="text-xs font-semibold">发掘</span>
                            </div>
                            <i data-lucide="chevron-right" class="w-6 h-6 lg:w-8 lg:h-8 text-finance-gold/50 flex-shrink-0"></i>
                            <div class="flex flex-col items-center gap-2 lg:gap-3">
                                <div class="w-14 h-14 lg:w-20 lg:h-20 rounded-full bg-tactical-green/20 border-2 border-tactical-green flex items-center justify-center">
                                    <i data-lucide="play-circle" class="w-6 h-6 lg:w-8 lg:h-8 text-tactical-green"></i>
                                </div>
                                <span class="text-xs font-semibold">决策</span>
                            </div>
                        </div>

                        <!-- 反身性循环指示 -->
                        <div class="text-center mb-4 lg:mb-6">
                            <i data-lucide="refresh-cw" class="w-8 h-8 mx-auto text-tech-cyan/50 animate-spin" style="animation-duration: 3s;"></i>
                            <span class="text-xs text-tech-cyan block mt-2">反身性增强循环</span>
                        </div>

                        <!-- 实战业绩 -->
                        <div class="bg-background/50 rounded-lg p-3 lg:p-4 mb-4 lg:mb-6">
                            <div class="text-xs sm:text-sm text-foreground/60 mb-2 lg:mb-3 flex items-center gap-2">
                                <i data-lucide="trophy" class="w-4 h-4"></i>
                                实战业绩（全部实盘）
                            </div>
                            <div class="grid grid-cols-2 gap-2 lg:gap-3">
                                <div class="flex justify-between items-center">
                                    <span class="text-xs lg:text-sm text-foreground/60">万有道1号</span>
                                    <span class="text-base lg:text-lg font-bold text-finance-gold flex items-center gap-1">
                                        <i data-lucide="trending-up" class="w-4 h-4"></i>
                                        489%
                                    </span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-xs lg:text-sm text-foreground/60">万有道2号</span>
                                    <span class="text-base lg:text-lg font-bold text-finance-gold flex items-center gap-1">
                                        <i data-lucide="trending-up" class="w-4 h-4"></i>
                                        234%
                                    </span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-xs lg:text-sm text-foreground/60">万有道3号</span>
                                    <span class="text-base lg:text-lg font-bold text-finance-gold flex items-center gap-1">
                                        <i data-lucide="trending-up" class="w-4 h-4"></i>
                                        252%
                                    </span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-xs lg:text-sm text-foreground/60">私人账户</span>
                                    <span class="text-base lg:text-lg font-bold text-finance-gold flex items-center gap-1">
                                        <i data-lucide="trending-up" class="w-4 h-4"></i>
                                        464%
                                    </span>
                                </div>
                            </div>
                        </div>

                        <button class="w-full py-2.5 lg:py-3 btn-primary font-semibold rounded-lg transition flex items-center justify-center gap-2">
                            <i data-lucide="key" class="w-5 h-5"></i>
                            申请模型授权
                        </button>
                    </div>
                </div>
            </div>
        </section>

        <!-- 核心优势 -->
        <section id="capabilities" class="py-12 lg:py-20 bg-card/30">
            <div class="container-custom">
                <h2 class="text-2xl lg:text-3xl font-bold mb-8 lg:mb-12 text-center flex items-center justify-center gap-3">
                    <i data-lucide="star" class="w-8 h-8 text-tech-cyan"></i>
                    核心优势
                </h2>
                <div class="grid md:grid-cols-3 gap-4 lg:gap-6">
                    <!-- 优势卡片1：极端市场专家 -->
                    <div class="bg-card border border-border rounded-lg p-4 lg:p-6 corner-deco card-hover">
                        <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-xl bg-tech-cyan/20 border border-tech-cyan/30 flex items-center justify-center mb-4">
                            <i data-lucide="zap" class="w-8 h-8 lg:w-10 lg:h-10 text-tech-cyan"></i>
                        </div>
                        <h3 class="text-lg lg:text-xl font-bold mb-3 lg:mb-4">极端市场专家</h3>
                        <ul class="space-y-2 lg:space-y-3 text-sm lg:text-base text-foreground/70">
                            <li class="flex items-start gap-2">
                                <i data-lucide="check-circle" class="w-5 h-5 text-tech-cyan mt-0.5 flex-shrink-0"></i>
                                2015股灾反向获利
                            </li>
                            <li class="flex items-start gap-2">
                                <i data-lucide="check-circle" class="w-5 h-5 text-tech-cyan mt-0.5 flex-shrink-0"></i>
                                所有账户正收益
                            </li>
                            <li class="flex items-start gap-2">
                                <i data-lucide="check-circle" class="w-5 h-5 text-tech-cyan mt-0.5 flex-shrink-0"></i>
                                严格风控体系
                            </li>
                            <li class="flex items-start gap-2">
                                <i data-lucide="check-circle" class="w-5 h-5 text-tech-cyan mt-0.5 flex-shrink-0"></i>
                                SXA反身性交易模型
                            </li>
                        </ul>
                    </div>

                    <!-- 优势卡片2：收并购全流程专家 -->
                    <div class="bg-card border border-border rounded-lg p-4 lg:p-6 corner-deco card-hover">
                        <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-xl bg-finance-gold/20 border border-finance-gold/30 flex items-center justify-center mb-4">
                            <i data-lucide="link" class="w-8 h-8 lg:w-10 lg:h-10 text-finance-gold"></i>
                        </div>
                        <h3 class="text-lg lg:text-xl font-bold mb-3 lg:mb-4">收并购全流程专家</h3>
                        <ul class="space-y-2 lg:space-y-3 text-sm lg:text-base text-foreground/70">
                            <li class="flex items-start gap-2">
                                <i data-lucide="check-circle" class="w-5 h-5 text-finance-gold mt-0.5 flex-shrink-0"></i>
                                品牌价值梳理
                            </li>
                            <li class="flex items-start gap-2">
                                <i data-lucide="check-circle" class="w-5 h-5 text-finance-gold mt-0.5 flex-shrink-0"></i>
                                成本重构优化
                            </li>
                            <li class="flex items-start gap-2">
                                <i data-lucide="check-circle" class="w-5 h-5 text-finance-gold mt-0.5 flex-shrink-0"></i>
                                渠道策划整合
                            </li>
                            <li class="flex items-start gap-2">
                                <i data-lucide="check-circle" class="w-5 h-5 text-finance-gold mt-0.5 flex-shrink-0"></i>
                                定价谈判撮合
                            </li>
                        </ul>
                    </div>

                    <!-- 优势卡片3：产业资源网络 -->
                    <div class="bg-card border border-border rounded-lg p-4 lg:p-6 corner-deco card-hover">
                        <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-xl bg-tactical-green/20 border border-tactical-green/30 flex items-center justify-center mb-4">
                            <i data-lucide="globe" class="w-8 h-8 lg:w-10 lg:h-10 text-tactical-green"></i>
                        </div>
                        <h3 class="text-lg lg:text-xl font-bold mb-3 lg:mb-4">产业资源网络</h3>
